# Twilio WhatsApp credentials
# Get these from https://console.twilio.com after rotating the auth token
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=whatsapp:+14155238886
# Optional: used only by smoke_twilio.py for a one-off live delivery test.
TWILIO_TO=whatsapp:+61XXXXXXXXX
# Required only when TEST_MODE=FALSE. Use "sandbox" or "registered".
TWILIO_WHATSAPP_MODE=sandbox

# Google Sheets service account
# Absolute path to the service account JSON key downloaded from Google Cloud Console
GOOGLE_SHEETS_CREDS_FILE=C:\path\to\google_credentials.json

# Runtime tuning
# Keep TEST_MODE=TRUE unless an operator is deliberately supervising live sends.
TEST_MODE=TRUE
MAX_PAGES=5
REQUEST_DELAY=1
SCRAPE_WORKERS=4
LISTING_CACHE_TTL_SECONDS=10800
LISTING_CACHE_PENDING_TTL_SECONDS=900
LISTING_CACHE_FILE=.runtime_cache/listing_detail_cache.json
TARGET_USER_ID=
FORCE_REFRESH=FALSE
